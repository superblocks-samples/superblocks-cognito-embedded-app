# Local environment for the Pre Token Generation Lambda.
#
#   cp cognito/lambda/env.example .env.lambda     # at repo root (gitignored)
#   # fill in the value below, then load into your shell:
#   set -a && source .env.lambda && set +a
#   node cognito/lambda/test-local.js you@mycompany.com

# Embed access token used to mint Superblocks session tokens via
# POST /api/v1/public/token. Create one in Superblocks Admin → Organization
# Settings → Access Tokens (token type: Embed).
SUPERBLOCKS_TOKEN=

# Optional. "app" (US, default) or "eu". Controls the token host
# (app.superblocks.com vs eu.superblocks.com).
# SUPERBLOCKS_REGION=app
