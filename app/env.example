# ============================================================================
# React Application - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local with real credentials to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Required Configuration
# ----------------------------------------------------------------------------

# Cognito User Pool (from AWS Console → Cognito → User Pools, or `aws cognito-idp describe-user-pool ...`)
REACT_APP_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
REACT_APP_COGNITO_USER_POOL_CLIENT_ID=your-cognito-app-client-id

# Hosted UI domain — the prefix you registered, plus `.auth.<region>.amazoncognito.com`
# (or your custom domain, without `https://`).
REACT_APP_COGNITO_DOMAIN=your-prefix.auth.us-east-1.amazoncognito.com

# Landing Superblocks application ID — the app served at "/" (and any
# top-level path that isn't /apps/<appId>/* or /login/callback). All other
# Superblocks apps are accessible at /apps/<appId>/* using their UUID, with
# no host-side registry. Leave unset to show a setup message at "/".
REACT_APP_SUPERBLOCKS_APPLICATION_ID=your-superblocks-app-id

# Your Superblocks instance URL (with https://)
REACT_APP_SUPERBLOCKS_URL=https://your-instance.superblocks.com

# ----------------------------------------------------------------------------
# Optional Configuration
# ----------------------------------------------------------------------------

# Override the Cognito Hosted UI redirect URLs. Defaults to the current
# window origin: <origin>/login/callback for sign-in and <origin>/ for
# sign-out. Set explicitly if the app is served behind a proxy/CDN that
# changes the visible origin.
# REACT_APP_COGNITO_REDIRECT_SIGN_IN=https://app.example.com/login/callback
# REACT_APP_COGNITO_REDIRECT_SIGN_OUT=https://app.example.com/

# Superblocks App Version: "1.0" (legacy) or "2.0" (code mode)
# REACT_APP_SUPERBLOCKS_APP_VERSION=2.0

# REACT_APP_ENV=development
