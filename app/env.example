# ============================================================================
# React Application — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to .env.local and fill in your actual values.
# Never commit .env.local with real credentials.
# ============================================================================

# ---- Required --------------------------------------------------------------

# Cognito User Pool (AWS Console → Cognito → User Pools, or
# `aws cognito-idp describe-user-pool ...`).
REACT_APP_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
REACT_APP_COGNITO_USER_POOL_CLIENT_ID=your-cognito-app-client-id

# Hosted UI / Managed Login domain — your registered prefix plus
# `.auth.<region>.amazoncognito.com` (or your custom domain, no `https://`).
REACT_APP_COGNITO_DOMAIN=your-prefix.auth.us-east-1.amazoncognito.com

# Your Superblocks instance origin (with https://, no trailing path).
REACT_APP_SUPERBLOCKS_URL=https://your-instance.superblocks.com

# ---- Optional --------------------------------------------------------------

# Landing Superblocks application ID — the app served at "/". Build a
# landing page in Superblocks (a list of apps, an integrations launcher,
# a dashboard, etc.) and paste its UUID here. Leave unset to show a
# placeholder at "/". Other apps still embed dynamically at
# /apps/<applicationId> using their UUID.
# REACT_APP_SUPERBLOCKS_APPLICATION_ID=your-superblocks-app-id

# Override the Cognito Hosted UI redirect URLs. Defaults to the current
# window origin: <origin>/login/callback for sign-in and <origin>/ for
# sign-out. Set explicitly if served behind a proxy/CDN that changes the
# visible origin.
# REACT_APP_COGNITO_REDIRECT_SIGN_IN=https://app.example.com/login/callback
# REACT_APP_COGNITO_REDIRECT_SIGN_OUT=https://app.example.com/

# Superblocks app version: "2.0" (code mode, default) or "1.0" (legacy).
# REACT_APP_SUPERBLOCKS_APP_VERSION=2.0
